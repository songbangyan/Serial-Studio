        { "type": "command", "id": "app.extensions", "gplOnly": true },
        { "type": "grid", "rows": 3, "pro": true,
          "itemHints": { "iconSize": 16, "horizontalLayout": true },
          "items": [
            { "type": "command", "id": "app.deploy", "title": "Deploy" },
            { "type": "command", "id": "app.sessions" },
            { "type": "command", "id": "app.extensions" }
          ] }
      ]
