          "itemHints": { "iconSize": 16, "horizontalLayout": true },
          "items": [
            { "type": "command", "id": "driver.uart" },
            { "type": "command", "id": "driver.audio" },
            { "type": "command", "id": "driver.usb" },
            { "type": "command", "id": "driver.network" },
            { "type": "command", "id": "driver.modbus" },
            { "type": "command", "id": "driver.hid" },
