{
  "surface": "main-toolbar",
  "sections": [
    {
      "type": "section",
      "items": [
        { "type": "command", "id": "app.projectEditor" },
        { "type": "grid", "rows": 3,
          "itemHints": { "iconSize": 16, "horizontalLayout": true },
          "items": [
            { "type": "command", "id": "project.open" },
            { "type": "command", "id": "csv.open" },
            { "type": "command", "id": "mdf4.open" }
          ] }
      ]
    },
    {
