            ],
            "painterCode": "// Stereo VU meter -- light theme, broadcast console aesthetic.\n// datasets[0] = left channel (dB FS), datasets[1] = right channel (dB FS).\n\nconst HOLD_MS   = 1400;\nconst FALL_DB_S = 18;       // peak-hold fall rate (dB per second)\nconst SEGMENTS  = 36;\nconst SEG_GAP   = 2;\n\n// dB scale and zone thresholds (relative to db_to_norm output)\nconst DB_LO = -60, DB_HI = 6;\nconst T_NOMINAL = 0.70;     // green up to here\nconst T_HOT     = 0.90;     // yellow up to here, red above\n\n// Marker dB positions\nconst TICKS_MAJOR = [-60, -40, -20, -10, -3, 0, 6];\nconst TICKS_MINOR = [-50, -30, -15, -6, 3];\n\nlet peakL = DB_LO, peakR = DB_LO;\nlet holdL = 0,     holdR = 0;\nlet lastTs = 0;\n\nfunction db_to_norm(db) {\n  return Math.max(0, Math.min(1, (db - DB_LO) / (DB_HI - DB_LO)));\n}\n\nfunction segment_color(t, lit) {\n  // Saturated when lit, soft pastel when unlit.\n  if (lit) {\n    if (t < T_NOMINAL) return \"#10b981\";   // emerald\n    if (t < T_HOT)     return \"#f59e0b\";   // amber\n    return \"#dc2626\";                      // crimson\n  } else {\n    if (t < T_NOMINAL) return \"#dcfce7\";   // pale emerald\n    if (t < T_HOT)     return \"#fef3c7\";   // pale amber\n    return \"#fee2e2\";                      // pale crimson\n  }\n}\n\nfunction onFrame() {\n  if (datasets.length < 2) return;\n\n  const now = Date.now();\n  const dt  = lastTs > 0 ? Math.max(0, (now - lastTs) * 1e-3) : 0;\n  lastTs    = now;\n\n  const l = datasets[0].value;\n  const r = datasets[1].value;\n\n  if (l > peakL) { peakL = l; holdL = now; }\n  else if (now - holdL > HOLD_MS) { peakL = Math.max(DB_LO, peakL - FALL_DB_S * dt); }\n\n  if (r > peakR) { peakR = r; holdR = now; }\n  else if (now - holdR > HOLD_MS) { peakR = Math.max(DB_LO, peakR - FALL_DB_S * dt); }\n}\n\nfunction draw_panel(ctx, x, y, w, h) {\n  // Outer card with thin border.\n  ctx.fillStyle = \"#ffffff\";\n  ctx.fillRect(x, y, w, h);\n  ctx.strokeStyle = \"#d4d4d8\";\n  ctx.lineWidth = 1;\n  ctx.strokeRect(x + 0.5, y + 0.5, w - 1, h - 1);\n\n  // Inset highlight at the top (1 px) and shadow at the bottom (1 px)\n  // to fake a subtle bevel.\n  ctx.fillStyle = \"#f8fafc\";\n  ctx.fillRect(x + 1, y + 1, w - 2, 1);\n  ctx.fillStyle = \"#e4e4e7\";\n  ctx.fillRect(x + 1, y + h - 2, w - 2, 1);\n}\n\nfunction draw_bar(ctx, x, y, w, h, level, peak) {\n  // Recessed track: light fill + inner shadow at the top.\n  ctx.fillStyle = \"#f1f5f9\";\n  ctx.fillRect(x, y, w, h);\n  ctx.fillStyle = \"#e2e8f0\";\n  ctx.fillRect(x, y, w, 1);\n  ctx.fillStyle = \"#ffffff\";\n  ctx.fillRect(x, y + h - 1, w, 1);\n\n  // Segmented bar -- every segment is drawn either lit (saturated) or\n  // unlit (pastel) so the meter's full length is visible even at silence.\n  const segW = (w - SEG_GAP * (SEGMENTS - 1)) / SEGMENTS;\n  for (let i = 0; i < SEGMENTS; ++i) {\n    const t   = (i + 0.5) / SEGMENTS;\n    const lit = t <= level;\n    ctx.fillStyle = segment_color(t, lit);\n    ctx.fillRect(x + i * (segW + SEG_GAP), y + 2, segW, h - 4);\n  }\n\n  // Peak hold marker -- a 2 px dark line with a faint halo on each side.\n  if (peak > 0) {\n    const px = x + w * peak;\n    ctx.fillStyle = \"#cbd5e1\";\n    ctx.fillRect(px - 2, y - 2, 1, h + 4);\n    ctx.fillRect(px + 2, y - 2, 1, h + 4);\n    ctx.fillStyle = \"#0f172a\";\n    ctx.fillRect(px - 1, y - 3, 2, h + 6);\n  }\n\n  // Outer frame.\n  ctx.strokeStyle = \"#94a3b8\";\n  ctx.lineWidth = 1;\n  ctx.strokeRect(x + 0.5, y + 0.5, w - 1, h - 1);\n}\n\nfunction draw_scale(ctx, x, y, w) {\n  // Tick rule under both bars.\n  ctx.fillStyle = \"#cbd5e1\";\n  ctx.fillRect(x, y, w, 1);\n\n  // Minor ticks.\n  ctx.fillStyle = \"#cbd5e1\";\n  for (let i = 0; i < TICKS_MINOR.length; ++i) {\n    const px = x + w * db_to_norm(TICKS_MINOR[i]);\n    ctx.fillRect(px, y, 1, 4);\n  }\n\n  // Major ticks + labels.\n  ctx.fillStyle = \"#475569\";\n  ctx.font = \"bold 10px sans-serif\";\n  ctx.textAlign = \"center\";\n  for (let i = 0; i < TICKS_MAJOR.length; ++i) {\n    const v  = TICKS_MAJOR[i];\n    const px = x + w * db_to_norm(v);\n    ctx.fillStyle = (v >= 0) ? \"#dc2626\" : \"#334155\";\n    ctx.fillRect(px, y, 1, 6);\n    const label = (v > 0 ? \"+\" + v : \"\" + v);\n    ctx.fillStyle = (v >= 0) ? \"#dc2626\" : \"#475569\";\n    ctx.fillText(label, px, y + 18);\n  }\n\n  // Nominal / hot threshold lines on the rule.\n  ctx.fillStyle = \"#f59e0b\";\n  ctx.fillRect(x + w * T_NOMINAL, y - 2, 1, 3);\n  ctx.fillStyle = \"#dc2626\";\n  ctx.fillRect(x + w * T_HOT, y - 2, 1, 3);\n}\n\nfunction paint(ctx, w, h) {\n  // Cream paper background with a hint of warmth.\n  ctx.fillStyle = \"#f5f5f1\";\n  ctx.fillRect(0, 0, w, h);\n\n  // Subtle vignette via a slightly darker frame around the edges.\n  ctx.strokeStyle = \"#e7e5de\";\n  ctx.lineWidth = 2;\n  ctx.strokeRect(1, 1, w - 2, h - 2);\n\n  if (datasets.length < 2) return;\n\n  // Card with bars sits inside an inner margin.\n  const pad = 14;\n  draw_panel(ctx, pad, pad, w - pad * 2, h - pad * 2);\n\n  // Header strip.\n  const headerY = pad + 10;\n  ctx.fillStyle = \"#0f172a\";\n  ctx.font = \"bold 11px sans-serif\";\n  ctx.textAlign = \"start\";\n  ctx.fillText(\"STEREO  VU\", pad + 16, headerY + 4);\n\n  ctx.fillStyle = \"#64748b\";\n  ctx.font = \"9px sans-serif\";\n  ctx.textAlign = \"end\";\n  ctx.fillText(\"dB FS\", w - pad - 16, headerY + 4);\n\n  // Subtle divider under the header.\n  ctx.fillStyle = \"#e5e7eb\";\n  ctx.fillRect(pad + 12, headerY + 12, w - (pad + 12) * 2, 1);\n\n  // Bars geometry.\n  const channelLabelW = 22;\n  const valueLabelW   = 56;\n  const x  = pad + 12 + channelLabelW;\n  const bw = w - pad * 2 - 24 - channelLabelW - valueLabelW;\n  const bh = 16;\n\n  // Vertically centre the L/R bar pair below the header.\n  const bodyTop  = headerY + 24;\n  const bodyBot  = h - pad - 32;          // leave room for scale + footer\n  const bodyMid  = (bodyTop + bodyBot) / 2;\n  const yL       = bodyMid - bh - 4;\n  const yR       = bodyMid + 4;\n\n  const lVal = datasets[0].value;\n  const rVal = datasets[1].value;\n\n  // Channel labels (L / R) -- bold serif-ish look done with bold sans + tracking.\n  ctx.fillStyle = \"#0f172a\";\n  ctx.font = \"bold 14px sans-serif\";\n  ctx.textAlign = \"center\";\n  ctx.fillText(\"L\", pad + 12 + channelLabelW * 0.5, yL + bh * 0.5 + 5);\n  ctx.fillText(\"R\", pad + 12 + channelLabelW * 0.5, yR + bh * 0.5 + 5);\n\n  // Bars.\n  draw_bar(ctx, x, yL, bw, bh, db_to_norm(lVal), db_to_norm(peakL));\n  draw_bar(ctx, x, yR, bw, bh, db_to_norm(rVal), db_to_norm(peakR));\n\n  // Per-channel numeric readouts on the right.\n  ctx.fillStyle = \"#0f172a\";\n  ctx.font = \"bold 12px sans-serif\";\n  ctx.textAlign = \"end\";\n  ctx.fillText(format_db(lVal), w - pad - 14, yL + bh * 0.5 + 4);\n  ctx.fillText(format_db(rVal), w - pad - 14, yR + bh * 0.5 + 4);\n\n  // Peak readouts -- small caption above each readout.\n  ctx.fillStyle = \"#94a3b8\";\n  ctx.font = \"9px sans-serif\";\n  ctx.fillText(\"pk \" + format_db(peakL), w - pad - 14, yL - 3);\n  ctx.fillText(\"pk \" + format_db(peakR), w - pad - 14, yR + bh + 11);\n\n  // dB scale rule below the bars.\n  draw_scale(ctx, x, yR + bh + 18, bw);\n\n  ctx.textAlign = \"start\";\n}\n\nfunction format_db(v) {\n  if (v <= DB_LO + 0.5) return \"-INF\";\n  if (v >= 0)           return \"+\" + v.toFixed(1);\n  return v.toFixed(1);\n}\n",
            "title": "VU Meter",
            "widget": "painter"
        },
        {
