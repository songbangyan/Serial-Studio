        {
            "title": "Vibration peak dial (Painter)",
            "widget": "painter",
            "painterCode": "// Smoothed dial gauge for peak vibration amplitude.\n// datasets[0] = vibration channel (g).\n\nconst PEAK_HOLD_MS = 1200;\nlet smoothed = 0;\nlet peak     = 0;\nlet peakAt   = 0;\nconst ALPHA  = 0.18;\n\nfunction onFrame() {\n  if (datasets.length === 0) return;\n  const v = Math.abs(datasets[0].value);\n  smoothed += ALPHA * (v - smoothed);\n\n  const now = Date.now();\n  if (v > peak) { peak = v; peakAt = now; }\n  else if (now - peakAt > PEAK_HOLD_MS) { peak = Math.max(0, peak - 0.04); }\n}\n\nfunction paint(ctx, w, h) {\n  ctx.fillStyle = \"#0b1220\";\n  ctx.fillRect(0, 0, w, h);\n\n  const cx = w / 2, cy = h * 0.62;\n  const r  = Math.min(w, h * 1.4) * 0.4;\n  const a0 = Math.PI * 0.85;\n  const a1 = Math.PI * 2.15;\n  const ds = (datasets.length > 0) ? datasets[0] : null;\n  const min = ds ? ds.min : 0;\n  const max = ds ? ds.max : 5;\n  const span = (max - min) || 1;\n\n  // coloured arc zones\n  function zone(v0, v1, color) {\n    const t0 = a0 + (a1 - a0) * ((v0 - min) / span);\n    const t1 = a0 + (a1 - a0) * ((v1 - min) / span);\n    ctx.beginPath();\n    ctx.arc(cx, cy, r, t0, t1);\n    ctx.lineWidth = 14;\n    ctx.strokeStyle = color;\n    ctx.stroke();\n  }\n  zone(min,            min + span * 0.6, \"#16a34a\");\n  zone(min + span * 0.6, min + span * 0.85, \"#facc15\");\n  zone(min + span * 0.85, max,             \"#ef4444\");\n\n  // tick marks\n  ctx.strokeStyle = \"#cbd5e1\";\n  ctx.lineWidth = 2;\n  for (let i = 0; i <= 10; ++i) {\n    const t = a0 + (a1 - a0) * (i / 10);\n    const x0 = cx + Math.cos(t) * (r - 18);\n    const y0 = cy + Math.sin(t) * (r - 18);\n    const x1 = cx + Math.cos(t) * (r - 6);\n    const y1 = cy + Math.sin(t) * (r - 6);\n    ctx.beginPath();\n    ctx.moveTo(x0, y0);\n    ctx.lineTo(x1, y1);\n    ctx.stroke();\n  }\n\n  // peak marker\n  if (peak > 0) {\n    const tp = a0 + (a1 - a0) * ((peak - min) / span);\n    ctx.strokeStyle = \"#fbbf24\";\n    ctx.lineWidth = 3;\n    ctx.beginPath();\n    ctx.moveTo(cx + Math.cos(tp) * (r - 22), cy + Math.sin(tp) * (r - 22));\n    ctx.lineTo(cx + Math.cos(tp) * (r + 4),  cy + Math.sin(tp) * (r + 4));\n    ctx.stroke();\n  }\n\n  // needle\n  const t = a0 + (a1 - a0) * ((smoothed - min) / span);\n  ctx.strokeStyle = \"#f8fafc\";\n  ctx.lineWidth = 3;\n  ctx.beginPath();\n  ctx.moveTo(cx, cy);\n  ctx.lineTo(cx + Math.cos(t) * (r - 10), cy + Math.sin(t) * (r - 10));\n  ctx.stroke();\n\n  ctx.fillStyle = \"#f8fafc\";\n  ctx.beginPath();\n  ctx.arc(cx, cy, 6, 0, Math.PI * 2);\n  ctx.fill();\n\n  // label\n  ctx.fillStyle = \"#e2e8f0\";\n  ctx.font = \"bold 16px sans-serif\";\n  ctx.textAlign = \"center\";\n  ctx.fillText(smoothed.toFixed(2) + \" g\", cx, h - 14);\n\n  ctx.fillStyle = \"#94a3b8\";\n  ctx.font = \"11px sans-serif\";\n  ctx.fillText(\"peak \" + peak.toFixed(2) + \" g\", cx, h - 30);\n  ctx.textAlign = \"start\";\n}\n",
