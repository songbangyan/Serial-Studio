        {
            "title": "Audio VU (Painter)",
            "widget": "painter",
            "painterCode": "// Stereo VU meter driven by mic_left + mic_right (dB FS).\n// datasets[0] = left, datasets[1] = right.\n\nconst HOLD_MS = 1500;\nconst SEGMENTS = 32;\nlet peakL = -60, peakR = -60;\nlet holdL = 0,   holdR = 0;\n\nfunction db_to_norm(db) {\n  const lo = -60, hi = 6;\n  return Math.max(0, Math.min(1, (db - lo) / (hi - lo)));\n}\n\nfunction segment_color(t) {\n  // t in [0, 1]; below 0.70 = green, 0.70-0.90 = yellow, above = red.\n  if (t < 0.70) return \"#16a34a\";\n  if (t < 0.90) return \"#facc15\";\n  return \"#ef4444\";\n}\n\nfunction paint_bar(ctx, x, y, w, h, level, peak) {\n  ctx.fillStyle = \"#0c0f14\";\n  ctx.fillRect(x, y, w, h);\n\n  // Segmented bar (LED-style) so we don't need a gradient.\n  const segGap = 1;\n  const segW   = (w - segGap * (SEGMENTS - 1)) / SEGMENTS;\n  for (let i = 0; i < SEGMENTS; ++i) {\n    const t = (i + 0.5) / SEGMENTS;\n    if (t > level) break;\n    ctx.fillStyle = segment_color(t);\n    ctx.fillRect(x + i * (segW + segGap), y, segW, h);\n  }\n\n  // Peak hold marker.\n  ctx.fillStyle = \"#ffffff\";\n  ctx.fillRect(x + w * peak - 1, y - 2, 2, h + 4);\n\n  ctx.strokeStyle = \"#1f2937\";\n  ctx.lineWidth = 1;\n  ctx.strokeRect(x + 0.5, y + 0.5, w - 1, h - 1);\n}\n\nfunction onFrame() {\n  if (datasets.length < 2) return;\n  const now = Date.now();\n  const l = datasets[0].value;\n  const r = datasets[1].value;\n\n  if (l > peakL) { peakL = l; holdL = now; }\n  else if (now - holdL > HOLD_MS) { peakL = Math.max(-60, peakL - 0.4); }\n\n  if (r > peakR) { peakR = r; holdR = now; }\n  else if (now - holdR > HOLD_MS) { peakR = Math.max(-60, peakR - 0.4); }\n}\n\nfunction paint(ctx, w, h) {\n  ctx.fillStyle = \"#0b1220\";\n  ctx.fillRect(0, 0, w, h);\n\n  if (datasets.length < 2) return;\n\n  ctx.fillStyle = \"#cbd5e1\";\n  ctx.font = \"bold 13px sans-serif\";\n  ctx.textAlign = \"start\";\n  ctx.fillText(\"L\", 6, h / 2 - 8);\n  ctx.fillText(\"R\", 6, h / 2 + 28);\n\n  const x = 28, bw = w - 40, bh = 18;\n  paint_bar(ctx, x, h / 2 - 22, bw, bh, db_to_norm(datasets[0].value), db_to_norm(peakL));\n  paint_bar(ctx, x, h / 2 + 14, bw, bh, db_to_norm(datasets[1].value), db_to_norm(peakR));\n\n  ctx.fillStyle = \"#94a3b8\";\n  ctx.font = \"10px sans-serif\";\n  ctx.textAlign = \"center\";\n  const labels = [\"-60\", \"-40\", \"-20\", \"-10\", \"-3\", \"0\", \"+6\"];\n  const dbs    = [-60,   -40,   -20,   -10,   -3,    0,    6];\n  for (let i = 0; i < labels.length; ++i) {\n    const px = x + bw * db_to_norm(dbs[i]);\n    ctx.fillText(labels[i], px, h / 2 + 50);\n    ctx.fillStyle = \"#334155\";\n    ctx.fillRect(px, h / 2 - 26, 1, 4);\n    ctx.fillRect(px, h / 2 + 32, 1, 4);\n    ctx.fillStyle = \"#94a3b8\";\n  }\n  ctx.textAlign = \"start\";\n}\n",
            "datasets": [
                {
                    "alarmEnabled": false,
