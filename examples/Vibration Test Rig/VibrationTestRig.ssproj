            "frameDetection": 0,
            "frameEnd": "\n",
            "frameParserCode": "/**\n * Comma-Separated Values (CSV) Parser\n *\n * Parses comma-separated data into an array of values.\n *\n * INPUT FORMAT: \"vibration,rpm,mic_left,mic_right\"\n * OUTPUT ARRAY: [\"vibration\", \"rpm\", \"mic_left\", \"mic_right\"]\n *\n * Note: Frame delimiters are automatically removed by Serial Studio.\n */\n\nfunction parse(frame) {\n  return frame.split(',');\n}\n",
            "frameStart": "",
