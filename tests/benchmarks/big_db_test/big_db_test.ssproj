                    ],
                    "datasetId": 0,
                    "decimalPoints": 2,
                    "displayFormat": "0d",
                    "displayTickCount": 19,
                    "fft": false,
                    "fftMax": 0,
                    "fftMin": 0,
                    "fftSamples": 256,
