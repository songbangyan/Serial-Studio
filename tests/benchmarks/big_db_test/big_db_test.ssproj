                    "plotMax": 26,
                    "plotMin": 0,
                    "title": "Channel 1",
                    "transformCode": "local __h1\n\nlocal alpha = 0.6  -- EMA smoothing factor (0.6 = balanced, responsive)\nlocal ema_ch1 = 0\n\nfunction transform(_value)\n  if __h1 == nil then __h1 = tableHandle(\"DAQ/TB/BRD-5\", \"ch1_val\") end\n  local raw = tableGetH(__h1) or 0xFFFF\n  if raw == 0xFFFF then return \"Disconnected\" end\n\n  if raw == 0xFFFE then return 26 end\n  if raw == 0xFFFD then return 0 end\n\n  local mA = raw / 1000\n  ema_ch1 = alpha * mA + (1 - alpha) * ema_ch1\n  return ema_ch1\nend\n",
                    "transformLanguage": 1,
                    "uniqueId": 252,
                    "units": "mA",
                    "value": "",
