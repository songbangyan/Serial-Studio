                    "title": "Channel 4",
                    "transformCode": "local __h1\n\nfunction transform(value)\n  if __h1 == nil then __h1 = tableHandle(\"DAQ/TC/BRD-4\", \"ch4_temp\") end\n  local raw = tableGetH(__h1) or 0xFFFF\n  if raw == 0xFFFF then\n    return \"Disconnected\"\n  end\n  -- Limit sentinels clamp to the gauge/plot limits: the gauge pegs and\n  -- the alarm bands fire instead of the plot breaking on a string. Keep\n  -- these two constants in sync with widgetMax/widgetMin and the bands.\n  if raw == 0xFFFE then\n    return 2600\n  end\n  if raw == 0xFFFD then\n    return \"Under Range\"\n  end\n  -- Device encoding: raw = (degC + 270) * 16; the frontend already\n  -- linearizes and compensates, so this is pure scaling.\n  local tempC = raw / 16 - 270\n  local tempF = (tempC * 9 / 5) + 32\n  return tempF\nend",
