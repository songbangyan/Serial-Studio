        {
            "datasets": [
                {
                    "datasetId": 0,
                    "displayFormat": "0d",
                    "displayTickCount": 5,
                    "fft": false,
                    "fftMax": 0,
                    "fftMin": 0,
                    "fftSamples": 256,
                    "fftSamplingRate": 100,
                    "graph": false,
                    "groupId": 33,
                    "index": 214,
                    "led": false,
                    "ledHigh": 80,
                    "log": false,
                    "numericValue": 0,
                    "plotMax": 0,
                    "plotMin": 0,
                    "title": "Reset Cause",
                    "transformCode": "local __sformat = string.format\nlocal __tconcat = table.concat\nlocal __band = bit32.band\nlocal RESET_CAUSES = {\n    [0x80] = \"Low Power\",\n    [0x40] = \"Window Watchdog\",\n    [0x20] = \"Watchdog Reset\",\n    [0x10] = \"Software Reset\",\n    [0x08] = \"Power-on Reset\",\n    [0x04] = \"Reset Pin\",\n    [0x02] = \"Config Reload\",\n  }\nlocal __h1\n\nfunction transform(value)\n  if __h1 == nil then __h1 = tableHandle(\"DAQ/TB/BRD-4\", \"boot_reset_cause\") end\n  local reset_cause = tableGetH(__h1) or 0\n  if reset_cause == 0x00 then\n    return \"No Reset\"\n  end\n  \n  local causes = {}\n\n  \n  for bit_val, cause_name in pairs(RESET_CAUSES) do\n    if __band(reset_cause, bit_val) ~= 0 then\n      causes[#causes+1] = cause_name\n    end\n  end\n  \n  if #causes == 0 then\n    return __sformat(\"Unknown 0x%02x\", reset_cause)\n  end\n  \n  return __tconcat(causes, \"+\")\nend",
                    "transformLanguage": 1,
                    "uniqueId": 248,
                    "units": "",
                    "value": "",
                    "virtual": true,
                    "widget": "",
                    "widgetMax": 0,
                    "widgetMin": 0,
                    "xAxis": -2
                },
                {
                    "datasetId": 1,
                    "displayFormat": "0d",
                    "displayTickCount": 5,
                    "fft": false,
                    "fftMax": 0,
                    "fftMin": 0,
                    "fftSamples": 256,
                    "fftSamplingRate": 100,
                    "graph": false,
                    "groupId": 33,
                    "index": 215,
                    "led": false,
                    "ledHigh": 80,
                    "log": false,
                    "numericValue": 0,
                    "plotMax": 0,
                    "plotMin": 0,
                    "title": "Self-Test Result",
                    "transformCode": "local __sformat = string.format\nlocal __h1\n\nfunction transform(value)\n  if __h1 == nil then __h1 = tableHandle(\"DAQ/TB/BRD-4\", \"boot_selftest\") end\n  local selftest = tableGetH(__h1) or 0\n  if selftest == 1 then\n    return \"ADC OK\"\n  elseif selftest == 0 then\n    return \"ADC Failure\"\n  else\n    return __sformat(\"Unknown (0x%02x)\", selftest)\n  end\nend",
                    "transformLanguage": 1,
                    "uniqueId": 249,
                    "units": "",
                    "value": "",
                    "virtual": true,
                    "widget": "",
                    "widgetMax": 0,
                    "widgetMin": 0,
                    "xAxis": -2
                },
                {
                    "datasetId": 2,
                    "displayFormat": "0d",
                    "displayTickCount": 5,
                    "fft": false,
                    "fftMax": 0,
                    "fftMin": 0,
                    "fftSamples": 256,
                    "fftSamplingRate": 100,
                    "graph": false,
                    "groupId": 33,
                    "index": 216,
                    "led": false,
                    "ledHigh": 80,
                    "log": false,
                    "numericValue": 0,
                    "plotMax": 0,
                    "plotMin": 0,
                    "title": "Last Calibration",
                    "transformCode": "local __tconcat = table.concat\nlocal __band = bit32.band\nlocal __h1\nlocal __h2\nlocal __h3\n\nfunction transform(value)\n  if __h1 == nil then __h1 = tableHandle(\"DAQ/TB/BRD-4\", \"cal_accepted\") end\n  if __h2 == nil then __h2 = tableHandle(\"DAQ/TB/BRD-4\", \"cal_stored\") end\n  if __h3 == nil then __h3 = tableHandle(\"DAQ/TB/BRD-4\", \"cal_time\") end\n  local m = tableGetH(__h1) or 256\n  local s = tableGetH(__h2) or 0\n  if m == 256 then\n    return \"None since boot\"\n  end\n  if m == 0 then\n    return \"All channels rejected\"\n  end\n  -- Bitmask: bit n = channel n+1 trimmed; device also reports whether the\n  -- trims were persisted and the host time of the run.\n  local chans = {}\n  for ch = 0, 7 do\n    if __band(m, bit32.lshift(1, ch)) ~= 0 then\n      chans[#chans+1] = tostring(ch + 1)\n    end\n  end\n  local suffix = (s == 1) and \" (stored)\" or \" (NOT stored)\"\n  local when = tableGetH(__h3)\n  if type(when) == \"string\" and when ~= \"\" then\n    suffix = suffix .. \" @ \" .. when\n  end\n  return \"Ch \" .. __tconcat(chans, \",\") .. suffix\nend",
                    "transformLanguage": 1,
                    "uniqueId": 250,
                    "units": "",
                    "value": "",
                    "virtual": true,
                    "widget": "",
                    "widgetMax": 0,
                    "widgetMin": 0,
                    "xAxis": -2
                }
            ],
            "parentFolderId": 7,
            "title": "TB-4 Boot Status",
            "uniqueId": 247,
            "widget": "datagrid"
