                    "sourceId": 0,
                    "title": "Calibrate Board 1",
                    "transmitFunction": "/**\n * Zero-offset calibration for TB board 1 — command 0.\n *\n * Command ID (type=2, board=1, cmd=0) = 0x608. Payload is a 4-byte\n * big-endian host Unix timestamp the board stamps into the calibration record.\n */\nfunction transmit(value) {\n  var epoch = Math.floor(Date.now() / 1000);\n  return canSendValue(0x608, epoch, 4);\n}\n"
                },
                {
                    "icon": "data:image/svg+xml;base64,",
