                    "transformCode": "local __sqrt = math.sqrt\nlocal __h1\n\nfunction transform(value)\n  if __h1 == nil then __h1 = tableHandle(\"DAQ/TA/BRD-3\", \"ch7_resistance\") end\n  local R_centiohms = tableGetH(__h1) or 0xFFFF\n  if R_centiohms == 0xFFFF then\n    return \"Disconnected\"\n  end\n  -- Limit sentinels clamp to the gauge/plot limits: the gauge pegs and\n  -- the alarm bands fire instead of the plot breaking on a string. Keep\n  -- these two constants in sync with widgetMax/widgetMin and the bands.\n  if R_centiohms == 0xFFFE then\n    return 1800\n  end\n  if R_centiohms == 0xFFFD then\n    return -350\n  end\n  local R = R_centiohms / 100\n  local R0 = 100\n  local A = 3.9083e-3\n  local B = -5.775e-7\n  local C = -4.183e-12\n  local ratio = 1 - (R / R0)\n  local discriminant = A * A - 4 * B * ratio\n  if discriminant < 0 then return \"Disconnected\" end\n  local tempC = (-A + __sqrt(discriminant)) / (2 * B)\n  -- Sub-zero (R < R0): the quadratic is only exact for T >= 0. Below 0 C\n  -- the C*(T-100)*T^3 term matters, so use the quadratic root as a seed and\n  -- refine on the full 4-term resistance-temperature curve with a few Newton\n  -- steps (converges to << 1 mC; T >= 0 readings are left untouched).\n  if R < R0 then\n    for i = 1, 4 do\n      local f = R0 * (1 + A * tempC + B * tempC * tempC + C * (tempC - 100) * tempC * tempC * tempC) - R\n      local df = R0 * (A + 2 * B * tempC + 4 * C * tempC * tempC * tempC - 300 * C * tempC * tempC)\n      tempC = tempC - f / df\n    end\n  end\n  local tempF = tempC * 9 / 5 + 32\n  return tempF\nend",
                    "transformLanguage": 1,
                    "uniqueId": 50,
                    "units": "°F",
                    "value": "",
                    "virtual": true,
                    "widget": "gauge",
                    "widgetMax": 1800,
                    "widgetMin": 0,
                    "xAxis": -2
                },
