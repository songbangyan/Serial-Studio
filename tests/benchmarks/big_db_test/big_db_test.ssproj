                    "title": "Channel 1",
                    "transformCode": "local __sformat = string.format\nlocal __h1\n\nfunction transform(value)\n  if __h1 == nil then __h1 = tableHandle(\"DAQ/TB/BRD-3\", \"ch1_mode\") end\n  local m = tableGetH(__h1) or 0\n  if m == 0 then\n    return \"Not Reported / Disabled\"\n  end\n  -- The device broadcasts the compile-time configured acquisition mode\n  -- as an ASCII letter: 'A' = current loop (uA), 'V' = voltage (0.02 mV).\n  if m == 65 then\n    return \"Current Loop\"\n  end\n  if m == 86 then\n    return \"Voltage Input\"\n  end\n  return __sformat(\"Unknown (0x%02x)\", m)\nend",
