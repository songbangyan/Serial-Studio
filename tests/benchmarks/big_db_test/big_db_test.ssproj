                    "plotMax": 0,
                    "plotMin": 0,
                    "title": "Last Calibration",
                    "transformCode": "local __tconcat = table.concat\nlocal __band = bit32.band\nlocal __h1\nlocal __h2\nlocal __h3\n\nfunction transform(value)\n  if __h1 == nil then __h1 = tableHandle(\"DAQ/TB/BRD-1\", \"cal_accepted\") end\n  if __h2 == nil then __h2 = tableHandle(\"DAQ/TB/BRD-1\", \"cal_stored\") end\n  if __h3 == nil then __h3 = tableHandle(\"DAQ/TB/BRD-1\", \"cal_time\") end\n  local m = tableGetH(__h1) or 256\n  local s = tableGetH(__h2) or 0\n  if m == 256 then\n    return \"None since boot\"\n  end\n  if m == 0 then\n    return \"All channels rejected\"\n  end\n  -- Bitmask: bit n = channel n+1 trimmed; device also reports whether the\n  -- trims were persisted and the host time of the run.\n  local chans = {}\n  for ch = 0, 7 do\n    if __band(m, bit32.lshift(1, ch)) ~= 0 then\n      chans[#chans+1] = tostring(ch + 1)\n    end\n  end\n  local suffix = (s == 1) and \" (stored)\" or \" (NOT stored)\"\n  local when = tableGetH(__h3)\n  if type(when) == \"string\" and when ~= \"\" then\n    suffix = suffix .. \" @ \" .. when\n  end\n  return \"Ch \" .. __tconcat(chans, \",\") .. suffix\nend",
                    "transformLanguage": 1,
                    "uniqueId": 157,
                    "units": "",
                    "value": "",
                    "virtual": true,
                    "widget": "",
                    "widgetMax": 0,
                    "widgetMin": 0,
                    "xAxis": -2
                }
            ],
