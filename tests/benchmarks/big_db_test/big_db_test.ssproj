                    "log": false,
                    "numericValue": 0,
                    "plotMax": 0,
                    "plotMin": 0,
                    "title": "Channel 1",
                    "transformCode": "local __sformat = string.format\nlocal __tconcat = table.concat\nlocal __band = bit32.band\nlocal FAULT_BITS = {\n    {0x80, \"Open Sensor (high rail)\"},\n    {0x40, \"Shorted Sensor (low rail)\"},\n    {0x20, \"Reference High\"},\n    {0x10, \"Reference Low\"},\n    {0x08, \"Input Low\"},\n    {0x04, \"Over/Undervoltage\"},\n  }\nlocal __h1\n\nfunction transform(value)\n  if __h1 == nil then __h1 = tableHandle(\"DAQ/TA/BRD-4\", \"ch1_diag\") end\n  local fault_byte = tableGetH(__h1) or 0xFF\n  if fault_byte == 0x00 then\n    return \"Connected\"\n  end\n  if fault_byte == 0xA5 then\n    return \"Software Reject (rail/tear/config/warm-up)\"\n  end\n  if fault_byte == 0xA6 then\n    return \"Above Device Limit\"\n  end\n  if fault_byte == 0xA7 then\n    return \"Below Device Limit\"\n  end\n  -- The frontend fault-status byte is a bitmask: several bits can be set at\n  -- once, so decode with bit tests and concatenate the labels.\n  local faults = {}\n\n  for _, fault in ipairs(FAULT_BITS) do\n    if __band(fault_byte, fault[1]) ~= 0 then\n      faults[#faults+1] = fault[2]\n    end\n  end\n  if #faults == 0 then\n    return __sformat(\"Fault 0x%02x\", fault_byte)\n  end\n  return __tconcat(faults, \" + \")\nend",
