{
    "actions": [
    ],
    "changeDrivenTransforms": true,
    "controlScriptCode": "/**\n * BigDB Watchdog Control Script\n *\n * Monitors frame arrival. If no frame is seen for WATCHDOG_TIMEOUT_MS the\n * whole fleet is marked as a communication loss and every channel on every\n * board (all three types, ids 1..6) is invalidated. Normal arrival clears it.\n */\n\nconst WATCHDOG_TIMEOUT_MS = 1000;\nconst BOARD_COUNT = 6;\nconst TYPES = [\n  { name: \"TA\", valkey: \"resistance\", extra: [] },\n  { name: \"TB\", valkey: \"val\",        extra: [\"mode\"] },\n  { name: \"TC\", valkey: \"temp\",       extra: [\"type\"] },\n];\n\nlet lastFrameTime = 0;\nlet watchdogTriggered = false;\n\nfunction setup() {\n  dashboardTick();\n}\n\nfunction markCommLoss() {\n  watchdogTriggered = true;\n\n  for (let t = 0; t < TYPES.length; t++) {\n    const ty = TYPES[t];\n    for (let brd = 1; brd <= BOARD_COUNT; brd++) {\n      const board = \"DAQ/\" + ty.name + \"/BRD-\" + brd;\n      tableSet(board, \"boot_reset_cause\", 0x01);\n      tableSet(board, \"boot_selftest\", 0xFF);\n\n      for (let ch = 1; ch <= 8; ch++) {\n        tableSet(board, \"ch\" + ch + \"_\" + ty.valkey, 0xFFFF);\n        tableSet(board, \"ch\" + ch + \"_diag\", 0xFF);\n        for (let e = 0; e < ty.extra.length; e++)\n          tableSet(board, \"ch\" + ch + \"_\" + ty.extra[e], 0x00);\n      }\n    }\n  }\n\n  refreshDashboard();\n  dashboardTick();\n}\n\nfunction clearCommLoss() {\n  watchdogTriggered = false;\n  notifyInfo(\"Information\", \"CAN communications restored\");\n}\n\nfunction loop() {\n  const frame = newFrame();\n\n  if (frame) {\n    lastFrameTime = Date.now();\n\n    if (watchdogTriggered)\n      clearCommLoss();\n\n    dashboardTick();\n  }\n  else if (lastFrameTime !== 0) {\n    const elapsed = Date.now() - lastFrameTime;\n    if (elapsed > WATCHDOG_TIMEOUT_MS && !watchdogTriggered) {\n      notifyCritical(\"CAN Bus Error\", \"No CAN frames received for \" + elapsed + \" milliseconds\");\n      markCommLoss();\n    }\n  }\n\n  delay(20);\n}\n",
    "customizeWorkspaces": true,
    "diagramCollapse": {
        "grp:66": true,
        "grp:67": true
    },
