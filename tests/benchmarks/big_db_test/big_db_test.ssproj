                    "transformCode": "local __sformat = string.format\nlocal __tconcat = table.concat\nlocal __band = bit32.band\nlocal RESET_CAUSES = {\n    [0x80] = \"Low Power\",\n    [0x40] = \"Window Watchdog\",\n    [0x20] = \"Watchdog Reset\",\n    [0x10] = \"Software Reset\",\n    [0x08] = \"Power-on Reset\",\n    [0x04] = \"Reset Pin\",\n    [0x02] = \"Config Reload\",\n  }\nlocal __h1\n\nfunction transform(value)\n  if __h1 == nil then __h1 = tableHandle(\"DAQ/TA/BRD-6\", \"boot_reset_cause\") end\n  local reset_cause = tableGetH(__h1) or 0\n  if reset_cause == 0x00 then\n    return \"No Reset\"\n  end\n  \n  local causes = {}\n\n  \n  for bit_val, cause_name in pairs(RESET_CAUSES) do\n    if __band(reset_cause, bit_val) ~= 0 then\n      causes[#causes+1] = cause_name\n    end\n  end\n  \n  if #causes == 0 then\n    return __sformat(\"Unknown 0x%02x\", reset_cause)\n  end\n  \n  return __tconcat(causes, \"+\")\nend",
                    "transformLanguage": 1,
                    "uniqueId": 125,
                    "units": "",
                    "value": "",
                    "virtual": true,
                    "widget": "",
                    "widgetMax": 0,
                    "widgetMin": 0,
                    "xAxis": -2
                },
