                    "transformCode": "local __sformat = string.format\nlocal __tconcat = table.concat\nlocal __band = bit32.band\nlocal FAULT_BITS = {\n    {0x02, \"Over/Undervoltage\"},\n    {0x04, \"Signal Low Threshold\"},\n    {0x08, \"Signal High Threshold\"},\n    {0x10, \"Aux Low Threshold\"},\n    {0x20, \"Aux High Threshold\"},\n    {0x40, \"Signal Out of Range\"},\n    {0x80, \"Aux Out of Range\"},\n  }\nlocal __h1\n\nfunction transform(value)\n  if __h1 == nil then __h1 = tableHandle(\"DAQ/TC/BRD-4\", \"ch8_diag\") end\n  local fault_byte = tableGetH(__h1) or 0xFF\n  if fault_byte == 0x00 then\n    return \"Connected\"\n  end\n  if fault_byte == 0xA5 then\n    return \"Software Reject (warm-up/tear/config)\"\n  end\n  if fault_byte == 0xA6 then\n    return \"Above Device Limit\"\n  end\n  if fault_byte == 0xA7 then\n    return \"Below Device Limit\"\n  end\n  if __band(fault_byte, 0x01) ~= 0 then\n    return \"Open Sensor\"\n  end\n  local faults = {}\n\n  for _, fault in ipairs(FAULT_BITS) do\n    if __band(fault_byte, fault[1]) ~= 0 then\n      faults[#faults+1] = fault[2]\n    end\n  end\n  if #faults == 0 then\n    return __sformat(\"Fault 0x%02x\", fault_byte)\n  end\n  return __tconcat(faults, \" + \")\nend",
