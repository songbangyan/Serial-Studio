                    "transformCode": "local __sformat = string.format\nlocal __h1\n\nfunction transform(value)\n  if __h1 == nil then __h1 = tableHandle(\"DAQ/TB/BRD-2\", \"ch4_diag\") end\n  local fault_byte = tableGetH(__h1) or 0xFF\n  if fault_byte == 0x00 then\n    return \"Connected\"\n  end\n  if fault_byte == 0xA5 then\n    return \"Software Reject (warm-up/CRC/config)\"\n  end\n  if fault_byte == 0xA6 then\n    return \"Above Device Limit\"\n  end\n  if fault_byte == 0xA7 then\n    return \"Below Device Limit\"\n  end\n  if fault_byte == 0xA8 then\n    return \"Open / Dead Loop\"\n  end\n  -- The ADC has no per-channel hardware fault register: every code\n  -- is generated by the device driver, so anything else is unexpected.\n  return __sformat(\"Fault 0x%02x\", fault_byte)\nend",
