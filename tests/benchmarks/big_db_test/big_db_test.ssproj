    "nextUniqueId": 610,
    "plotTimeRange": 10,
    "pointCount": 1000,
    "schemaVersion": 3,
    "sources": [
        {
            "busType": 1,
            "checksum": "",
            "checksumAlgorithm": "",
            "connection": {
                "address": "localhost",
                "socketTypeIndex": 1,
                "udpLocalPort": 8080,
                "udpMulticast": false,
                "udpRemotePort": 8080
            },
            "decoder": 3,
            "decoderMethod": 3,
            "frameDetection": 2,
            "frameEnd": "\n",
            "frameParserCode": "/**\n * BigDB unified parser - decodes all three board types onto one bus.\n *\n * 11-bit standard CAN ID:\n *   bits [9:8] board type  (1 = TA, 2 = TB, 3 = TC)\n *   bits [7:3] board id    (1..6)\n *   bits [2:0] reading id  (0/1 data, 2 diag, 5 cal[TB], 6 info, 7 boot)\n *\n * Readings land in a per-board table named \"DAQ/<TYPE>/BRD-<id>\" (e.g. \"DAQ/TA/BRD-3\"),\n * so the same board id across different types never collides.\n *\n * Hot path: each board's register names are resolved to table handles once, on\n * the first frame for that board, and then read/written via tableGetH/tableSetH,\n * so no register-name string is built or hashed per frame. Falls back to the\n * name-based tableGet/tableSet on builds without the handle API.\n */\n\nconst BUNDLES = {};\nconst TYPE_NAMES = { 1: \"TA\", 2: \"TB\", 3: \"TC\" };\nconst VAL_KEY    = { 1: \"resistance\", 2: \"val\", 3: \"temp\" };\n\nconst HAVE_HANDLES = (typeof tableHandle === \"function\");\n\nfunction resolve(table, reg) {\n  return HAVE_HANDLES ? tableHandle(table, reg) : reg;\n}\n\nfunction rget(b, h) {\n  return HAVE_HANDLES ? tableGetH(h) : tableGet(b.table, h);\n}\n\nfunction rset(b, h, v) {\n  if (HAVE_HANDLES)\n    tableSetH(h, v);\n  else\n    tableSet(b.table, h, v);\n}\n\nfunction makeBundle(board_type, table, valkey) {\n  const b = { table: table, val: [], diag: [], mode: [] };\n  for (let ch = 1; ch <= 8; ch++) {\n    b.val[ch]  = resolve(table, \"ch\" + ch + \"_\" + valkey);\n    b.diag[ch] = resolve(table, \"ch\" + ch + \"_diag\");\n  }\n  \n  b.boot_reset = resolve(table, \"boot_reset_cause\");\n  b.boot_self  = resolve(table, \"boot_selftest\");\n\n  if (board_type === 2) {\n    for (let ch = 1; ch <= 8; ch++)\n      b.mode[ch] = resolve(table, \"ch\" + ch + \"_mode\");\n    b.cal_accepted = resolve(table, \"cal_accepted\");\n    b.cal_stored   = resolve(table, \"cal_stored\");\n    b.cal_epoch    = resolve(table, \"cal_epoch\");\n    b.cal_time     = resolve(table, \"cal_time\");\n  }\n\n  if (board_type === 3)\n    for (let ch = 1; ch <= 8; ch++)\n      b.mode[ch] = resolve(table, \"ch\" + ch + \"_type\");\n\n  return b;\n}\n\nfunction bundleFor(board_type, board_id, table, valkey) {\n  const key = board_type + \"-\" + board_id;\n  let b = BUNDLES[key];\n  if (!b) {\n    b = makeBundle(board_type, table, valkey);\n    BUNDLES[key] = b;\n  }\n  \n  return b;\n}\n\nfunction decode_can_id(id) {\n  const board_type = (id >> 8) & 0x03;\n  const board_id = (id >> 3) & 0x1F;\n  const reading_id = id & 0x07;\n  return { board_type, board_id, reading_id };\n}\n\nfunction u16_be(frame, byte_offset) {\n  const frame_index = 3 + byte_offset;\n  if (frame_index + 1 >= frame.length)\n    return 0xFFFF;\n\n  return (frame[frame_index] * 256) + frame[frame_index + 1];\n}\n\nfunction set_block(b, base_ch, frame) {\n  for (let i = 0; i < 4; i++) {\n    const v = u16_be(frame, i * 2);\n    const ch = base_ch + i;\n\n    rset(b, b.val[ch], v);\n    if (v < 0xFFFD)\n      rset(b, b.diag[ch], 0x00);\n  }\n}\n\nfunction parse(frame) {\n  if (!frame || frame.length < 3) {\n    if (io.getStatus().isConnected)\n      console.log(\"[BigDB] ERROR: Frame too short: \" + (frame ? frame.length : 0) + \" bytes\");\n\n    return [];\n  }\n\n  const can_id = (frame[0] * 256) + frame[1];\n  if ((can_id & 0x400) !== 0) {\n    return []; \n  }\n  \n  const { board_type, board_id, reading_id } = decode_can_id(can_id);\n  const type_name = TYPE_NAMES[board_type];\n  \n  if (!type_name) {\n    console.log(\"[BigDB] SKIP: unknown board_type=\" + board_type);\n    return [];\n  }\n\n  const table = \"DAQ/\" + type_name + \"/BRD-\" + board_id;\n  const valkey = VAL_KEY[board_type];\n  const b = bundleFor(board_type, board_id, table, valkey);\n\n  if (reading_id === 0) {\n    if (frame.length < 11)\n      return [];\n\n    set_block(b, 1, frame);\n  }\n\n  else if (reading_id === 1) {\n    if (frame.length < 11)\n      return [];\n\n    set_block(b, 5, frame);\n  }\n\n  else if (reading_id === 2) {\n    if (frame.length < 11)\n      return [];\n\n    for (let ch = 1; ch <= 8; ch++) {\n      const fault = frame[3 + (ch - 1)];\n      rset(b, b.diag[ch], fault);\n      if (fault !== 0x00 && fault !== 0xA6 && fault !== 0xA7)\n        rset(b, b.val[ch], 0xFFFF);\n    }\n  }\n\n  else if (reading_id === 5 && board_type === 2) {\n    if (frame.length < 5)\n      return [];\n\n    rset(b, b.cal_accepted, frame[3]);\n    rset(b, b.cal_stored, frame[4]);\n\n    if (frame.length >= 9) {\n      const cal_epoch = (frame[5] * 16777216) + (frame[6] * 65536) + (frame[7] * 256) + frame[8];\n      rset(b, b.cal_epoch, cal_epoch);\n      if (cal_epoch > 0) {\n        const cal_date = new Date(cal_epoch * 1000);\n        const pad = function (n) { return (n < 10 ? \"0\" : \"\") + n; };\n        rset(b, b.cal_time,\n                 cal_date.getUTCFullYear() + \"-\" + pad(cal_date.getUTCMonth() + 1) + \"-\" + pad(cal_date.getUTCDate())\n                 + \" \" + pad(cal_date.getUTCHours()) + \":\" + pad(cal_date.getUTCMinutes()) + \" UTC\");\n      } else {\n        rset(b, b.cal_time, \"\");\n      }\n    }\n  }\n\n  else if (reading_id === 6) {\n    if (frame.length < 11)\n      return [];\n\n    if (board_type === 2 || board_type === 3)\n      for (let ch = 1; ch <= 8; ch++)\n        rset(b, b.mode[ch], frame[3 + (ch - 1)]);\n  }\n\n  else if (reading_id === 7) {\n    if (frame.length < 5)\n      return [];\n\n    rset(b, b.boot_reset, frame[3]);\n    rset(b, b.boot_self, frame[4]);\n  }\n\n  return [];\n}\n",
            "frameParserParams": {
                "quoteChar": "",
                "separator": ",",
                "skipEmpty": false,
                "trimFields": false
            },
